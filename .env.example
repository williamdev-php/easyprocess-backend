# =============================================================================
# Qvicko Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the real .env file to git.
# =============================================================================

# Environment: "development" or "production"
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/postgres
DATABASE_URL_DIRECT=
DATABASE_READ_REPLICA_URL=

# ---------------------------------------------------------------------------
# Auth / JWT
# ---------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Supabase Storage
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=qvicko

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=
REDIS_INTERNAL_URL=

# ---------------------------------------------------------------------------
# Email (Resend)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@qvicko.com
RESEND_FROM_NAME=Qvicko
RESEND_WEBHOOK_SECRET=
RESEND_INBOUND_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# AI
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
GOOGLE_AI_API_KEY=

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
AUTOBLOGGER_FRONTEND_URL=http://localhost:3002
FEYRA_FRONTEND_URL=http://localhost:3005
VIEWER_URL=http://localhost:3001
PORT=8000

# ---------------------------------------------------------------------------
# Email addresses
# ---------------------------------------------------------------------------
EMAIL_WILLIAM=william@qvicko.com
EMAIL_HELP=help@qvicko.com
EMAIL_NOREPLY=noreply@qvicko.com

# ---------------------------------------------------------------------------
# Domain
# ---------------------------------------------------------------------------
BASE_DOMAIN=qvickosite.com

# ---------------------------------------------------------------------------
# Vercel (custom domain management)
# ---------------------------------------------------------------------------
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Stripe Connect (marketplace payments)
STRIPE_CONNECT_WEBHOOK_SECRET=
PLATFORM_FEE_PERCENT=0.2

# AutoBlogger Stripe plans
STRIPE_AUTOBLOGGER_PRO_PRICE_ID=
STRIPE_AUTOBLOGGER_BUSINESS_PRICE_ID=

# ---------------------------------------------------------------------------
# Encryption keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ---------------------------------------------------------------------------
FEYRA_ENCRYPTION_KEY=
AUTOBLOGGER_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Shopify OAuth (AutoBlogger)
# ---------------------------------------------------------------------------
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ---------------------------------------------------------------------------
# Viewer
# ---------------------------------------------------------------------------
REVALIDATION_SECRET=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
SITE_RATE_LIMIT_ENABLED=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3005
